# Example environment variables for CraftConnect
# Copy this file to .env and update with your values

# Database Configuration
POSTGRES_USER=craftconnect
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=craftconnect_db
DATABASE_URL=postgresql://craftconnect:your_secure_password_here@db:5432/craftconnect_db

# Redis Configuration
REDIS_URL=redis://redis:6379

# Backend Configuration
PORT=4000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long
CORS_ORIGIN=http://localhost:5173

# Admin Credentials
ADMIN_EMAIL=admin@craftconnect.com
ADMIN_PASSWORD=change_this_in_production

# Frontend Configuration (optional)
# VITE_API_URL=http://localhost:4000/api
